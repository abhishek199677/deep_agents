# =============================================================================
# Deep Agents — Production Configuration
# Copy this to .env and fill in your real values.
# NEVER commit .env to version control.
# =============================================================================

# --- LLM Providers (at least one required) ---
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# --- Web Search ---
TAVILY_API_KEY=

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+psycopg://agentic:agentic@postgres:5432/agentic
POSTGRES_USER=agentic
POSTGRES_PASSWORD=agentic
POSTGRES_DB=agentic

# --- Redis (rate limiting + caching) ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=72

# --- App ---
APP_NAME=Deep Agents
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_DAY=500

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

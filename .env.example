# =============================================================================
# Deep Agents — Production Configuration Template
# Copy this to .env (for local dev) or set as environment variables in prod.
# NEVER commit .env to version control.
# =============================================================================

# --- LLM Providers (at least one required) ---
OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Web Search ---
TAVILY_API_KEY=tvly-...

# --- Database (PostgreSQL) ---
POSTGRES_USER=agentic
POSTGRES_PASSWORD=<generate-a-strong-password>
POSTGRES_DB=agentic

# --- Redis ---
# (no auth needed if using docker internal network)

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- Domain ---
DOMAIN=yourdomain.com

# --- SSL ---
# Path to SSL certificate files (for Let's Encrypt or similar)
# SSL_CERT_DIR=./certs
# SSL_KEY_DIR=./certs

# --- Monitoring ---
# SENTRY_DSN=https://...

# --- App ---
APP_NAME=Deep Agents
APP_ENV=development
LOG_LEVEL=INFO

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_DAY=500

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
